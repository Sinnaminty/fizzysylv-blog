        <a href="/">Home</a>
        <a href="#top">Blog</a>
      </nav>
    </div>
  </header>

  <main id="top">
    <section class="hero small">
      <div class="container">
        <p class="eyebrow">log directory</p>
        <h1>Fizzy’s Log</h1>
        <p class="hero-subtitle">
          Dev notes, con stories, music brainworms, and whatever else I feel
          like yelling into the void about.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2>Posts</h2>
        <ul class="post-list">
          <li class="post-item">
            <a href="first-post.html" class="post-title">Booting fizzysylv.xyz</a>
            <p class="post-meta">2025-01-01 • meta, site</p>
            <p class="post-excerpt">
              How this tiny corner of the internet came to be, what I want to
